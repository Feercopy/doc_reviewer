{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gate-challenger.local/schemas/benchmark-judge-result.schema.json",
  "title": "BenchmarkJudgeResult",
  "type": "object",
  "required": ["layer_1", "layer_2", "summary", "recommendations"],
  "additionalProperties": false,
  "properties": {
    "layer_1": { "$ref": "#/$defs/layer_judgement" },
    "layer_2": { "$ref": "#/$defs/layer_judgement" },
    "summary": { "type": "string" },
    "recommendations": { "type": "array", "items": {} }
  },
  "$defs": {
    "layer_judgement": {
      "type": "object",
      "required": ["exact_matches", "partial_matches", "missed_findings", "false_positives"],
      "additionalProperties": false,
      "properties": {
        "exact_matches": { "type": "array", "items": {} },
        "partial_matches": { "type": "array", "items": {} },
        "missed_findings": { "type": "array", "items": {} },
        "false_positives": { "type": "array", "items": {} }
      }
    }
  }
}
