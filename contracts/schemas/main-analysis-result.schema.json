{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gate-challenger.local/schemas/main-analysis-result.schema.json",
  "title": "MainAnalysisResult",
  "type": "object",
  "required": ["verdict", "summary", "findings", "checks"],
  "additionalProperties": false,
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "approve_with_conditions", "need_evidence", "reject", "unknown"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "key_findings": { "type": "array", "items": { "type": "string" } },
    "layer_1": { "type": "array", "items": { "type": "object" } },
    "layer_2": { "type": "array", "items": { "type": "object" } }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["id", "severity", "title", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "title": { "type": "string", "minLength": 1 },
        "evidence": { "type": "string", "minLength": 1 }
      }
    },
    "check": {
      "type": "object",
      "required": ["name", "status"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["pass", "partial", "fail", "not_applicable"] },
        "explanation": { "type": "string" }
      }
    }
  }
}
