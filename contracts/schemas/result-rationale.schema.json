{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gate-challenger.local/schemas/result-rationale.schema.json",
  "title": "ResultRationale",
  "type": "object",
  "required": ["run_mode", "rationale_markdown", "rationale_items", "critical_risks", "data_gaps"],
  "additionalProperties": false,
  "properties": {
    "run_mode": { "type": "string", "const": "result_rationale" },
    "rationale_markdown": { "type": "string", "minLength": 120, "maxLength": 4000 },
    "rationale_items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["title", "detail", "sources"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 240 },
          "detail": { "type": "string", "minLength": 1, "maxLength": 1400 },
          "sources": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "uniqueItems": true,
            "items": { "type": "string", "enum": ["gate_challenger", "ic_review"] }
          }
        }
      }
    },
    "critical_risks": {
      "type": "array",
      "maxItems": 7,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "data_gaps": {
      "type": "array",
      "maxItems": 7,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    }
  }
}
